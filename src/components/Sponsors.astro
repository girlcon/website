---
import { sponsors } from '../data/sponsors.js';
// Duplicate list so the marquee can loop seamlessly
const doubled = [...sponsors, ...sponsors];
---

<section id="sponsors" class="py-24 px-6 bg-white">
  <div class="max-w-5xl mx-auto text-center mb-12 fade-up">
    <p class="text-xs font-semibold tracking-[0.15em] uppercase text-[#a180be] mb-3">Our Partners</p>
    <h2 class="font-['Playfair_Display'] text-4xl md:text-5xl font-bold text-[#1a1225] mb-4">
      GirlCon Sponsors
    </h2>
    <p class="text-[#7c6f8a] max-w-md mx-auto">
      GirlCon would not be possible without all of our generous sponsors.
    </p>
  </div>

  <!-- Infinite marquee -->
  <div class="marquee-wrap overflow-hidden fade-up" style="transition-delay: 0.1s;">
    <div class="marquee-track flex items-center gap-16 w-max py-4">
      {doubled.map((sponsor) => (
        <a
          href={sponsor.url}
          target="_blank"
          rel="noopener noreferrer"
          class="flex-shrink-0 grayscale hover:grayscale-0 opacity-60 hover:opacity-100 transition-all duration-300"
          title={sponsor.name}
        >
          <img
            src={sponsor.logo}
            alt={sponsor.name}
            class="h-10 w-auto object-contain"
            onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex';`}
          />
          <!-- Text fallback if logo image is missing -->
          <span
            class="hidden items-center justify-center h-10 px-5 rounded-lg bg-[#f3ecf8] text-[#6b4fa0] font-semibold text-sm"
          >{sponsor.name}</span>
        </a>
      ))}
    </div>
  </div>

  <!-- Become a sponsor CTA -->
  <div class="text-center mt-14 fade-up" style="transition-delay: 0.2s;">
    <p class="text-[#7c6f8a] mb-4">
      Interested in sponsoring GirlCon?
    </p>
    <a
      href="/sponsorship-prospectus.pdf"
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-2 px-6 py-3 rounded-full border-2 border-[#a180be] text-[#6b4fa0] font-semibold hover:bg-[#a180be] hover:text-white transition-colors"
    >
      View Sponsorship Prospectus
      <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none">
        <path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </a>
  </div>
</section>
