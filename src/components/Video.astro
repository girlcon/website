---
// Featured video section — GirlCon 2026 YouTube sessions
const videos = [
  {
    id: "fbo24GQFV-k",
    title: "GirlCon 2026 Virtual Opening Session + Keynote",
    description: "GirlCon invites you to watch our opening ceremony from our 2026 virtual event.",
  },
  {
    id: "-etKjCeDaxQ",
    title: "GirlCon 2026 — Closing Ceremony + Keynote",
    description: "Join us for the closing ceremony and keynote from GirlCon 2026.",
  },
];
---

<section id="watch" class="py-24 px-6 bg-[#fff8f4]">
  <div class="max-w-5xl mx-auto">

    <div class="text-center mb-14 fade-up">
      <p class="text-xs font-semibold tracking-[0.15em] uppercase text-[#a180be] mb-3">Watch</p>
      <h2 class="font-['Open_Sauce_Sans'] text-4xl md:text-5xl font-bold text-[#1a1225]">
        GirlCon 2026 Sessions
      </h2>
      <p class="text-[#7c6f8a] mt-4 max-w-md mx-auto">
        Catch up on our live-streamed sessions from GirlCon 2026.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8">
      {videos.map((video, i) => (
        <div class="fade-up" style={`transition-delay: ${i * 0.12}s;`}>
          <div class="rounded-2xl overflow-hidden shadow-lg shadow-purple-200/30 bg-white">
            <div class="aspect-video w-full">
              <iframe
                src={`https://www.youtube.com/embed/${video.id}`}
                title={video.title}
                class="w-full h-full"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
                loading="lazy"
              ></iframe>
            </div>
            <div class="p-5">
              <h3 class="font-semibold text-[#1a1225] leading-snug mb-1">{video.title}</h3>
              <p class="text-sm text-[#7c6f8a]">{video.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>
