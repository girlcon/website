---
// Hero section — full viewport, animated orbs, GirlCon wordmark
---

<section
  id="hero"
  class="relative min-h-screen flex flex-col items-center justify-center overflow-hidden bg-[#fff8f4]"
>

  <!-- Animated background orbs -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <!-- Large orb, top-left -->
    <div
      class="orb-a absolute -top-32 -left-32 w-[600px] h-[600px] rounded-full"
      style="background: radial-gradient(circle, rgba(161,128,190,0.50) 0%, rgba(161,128,190,0.18) 45%, transparent 70%);"
    ></div>
    <!-- Medium orb, bottom-right -->
    <div
      class="orb-b absolute -bottom-24 -right-24 w-[500px] h-[500px] rounded-full"
      style="background: radial-gradient(circle, rgba(107,79,160,0.42) 0%, rgba(107,79,160,0.14) 45%, transparent 70%);"
    ></div>
    <!-- Small orb, center-right -->
    <div
      class="orb-c absolute top-1/3 right-1/4 w-[280px] h-[280px] rounded-full"
      style="background: radial-gradient(circle, rgba(161,128,190,0.38) 0%, rgba(161,128,190,0.10) 45%, transparent 70%);"
    ></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-6 max-w-4xl mx-auto">

    <!-- Eyebrow -->
    <p class="text-sm font-semibold tracking-[0.18em] uppercase text-[#a180be] mb-6 fade-up">
      International Tech Conference for Womxn
    </p>

    <!-- Main title -->
    <h1
      class="font-['Open_Sauce_Sans'] text-[clamp(4rem,12vw,9rem)] font-bold leading-none tracking-tight text-[#1a1225] mb-6 fade-up"
      style="transition-delay: 0.1s;"
    >
      GirlCon
    </h1>

    <!-- Tagline -->
    <p
      class="text-lg md:text-xl text-[#7c6f8a] max-w-xl mx-auto mb-10 leading-relaxed fade-up"
      style="transition-delay: 0.2s;"
    >
      Empowering the next generation of leaders through technology, mentorship, and community — in its ninth year.
    </p>

    <!-- CTAs -->
    <div class="flex flex-wrap gap-4 justify-center fade-up" style="transition-delay: 0.3s;">
      <a
        href="/#about"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full bg-[#a180be] text-white font-medium hover:bg-[#6b4fa0] transition-colors shadow-lg shadow-purple-300/30"
      >
        Explore GirlCon
      </a>
      <a
        href="/#contact"
        class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full border border-[#a180be] text-[#6b4fa0] font-medium hover:bg-[#a180be] hover:text-white transition-colors"
      >
        Get Involved
      </a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-10 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-[#a180be] opacity-60">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <svg class="w-4 h-4 animate-bounce" viewBox="0 0 16 16" fill="none">
      <path d="M8 3v10M3 8l5 5 5-5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

</section>
