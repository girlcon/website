---
// Past Events infinite photo marquee — two rows, opposite directions.
// Row 1 scrolls left, row 2 scrolls right.
// Add real photo filenames to each array below.
// Images go in: public/images/events/
const photosRow1 = [
  { src: "/images/events/event-01.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-02.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-03.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-04.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-05.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-06.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-07.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-08.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-09.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-10.jpg", alt: "GirlCon event photo" },
];

const photosRow2 = [
  { src: "/images/events/event-11.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-12.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-13.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-14.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-15.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-16.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-17.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-18.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-19.jpg", alt: "GirlCon event photo" },
  { src: "/images/events/event-20.jpg", alt: "GirlCon event photo" },
];

// Duplicate each row for seamless infinite loop
const doubled1 = [...photosRow1, ...photosRow1];
const doubled2 = [...photosRow2, ...photosRow2];

const years = [2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025];
---

<section id="past-events" class="py-24 bg-white overflow-hidden">
  <div class="max-w-5xl mx-auto px-6 mb-12 fade-up">
    <div class="text-center">
      <p class="text-xs font-semibold tracking-[0.15em] uppercase text-[#a180be] mb-3">Our History</p>
      <h2 class="font-['Open_Sauce_Sans'] text-4xl md:text-5xl font-bold text-[#1a1225] mb-5">
        Past Events
      </h2>
      <p class="text-[#7c6f8a] max-w-lg mx-auto">
        Thank you to everyone who helped make GirlCon
        {years.map((y, i) => (
          <span>{y}{i < years.length - 1 ? ', ' : ''}</span>
        ))} possible. We couldn't have done it without you.
      </p>
    </div>
  </div>

  <!-- Row 1: scrolls left -->
  <div class="photo-marquee-wrap overflow-hidden fade-up" style="transition-delay: 0.1s;">
    <div class="photo-marquee-track flex items-center gap-4 w-max py-3">
      {doubled1.map((photo) => (
        <div class="w-72 rounded-2xl overflow-hidden shadow-md shadow-purple-100/50 flex-shrink-0">
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-52 object-cover"
            onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex';`}
            loading="lazy"
          />
          <div
            class="w-full h-52 hidden items-center justify-center"
            style="background: linear-gradient(135deg, #f3ecf8 0%, #e0cff0 100%);"
          ></div>
        </div>
      ))}
    </div>
  </div>

  <!-- Row 2: scrolls right -->
  <div class="photo-marquee-wrap overflow-hidden fade-up" style="transition-delay: 0.2s;">
    <div class="photo-marquee-track-reverse flex items-center gap-4 w-max py-3">
      {doubled2.map((photo) => (
        <div class="w-72 rounded-2xl overflow-hidden shadow-md shadow-purple-100/50 flex-shrink-0">
          <img
            src={photo.src}
            alt={photo.alt}
            class="w-full h-52 object-cover"
            onerror={`this.style.display='none'; this.nextElementSibling.style.display='flex';`}
            loading="lazy"
          />
          <div
            class="w-full h-52 hidden items-center justify-center"
            style="background: linear-gradient(135deg, #ede0fa 0%, #d5bef5 100%);"
          ></div>
        </div>
      ))}
    </div>
  </div>
</section>
