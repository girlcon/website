---
// Past Events infinite photo marquee — two rows, opposite directions.
// Photos are shuffled randomly on each page load via client-side JS.
// To add new photos: drop them in public/images/events/ and update the count below.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const photoCount = 25;
const allPhotos = Array.from({ length: photoCount }, (_, i) => ({
  src: `${base}/images/events/event-${String(i + 1).padStart(2, '0')}.jpg`,
  alt: "GirlCon event photo",
}));

const years = [2018, 2019, 2020, 2021, 2022, 2023, 2024, 2025, 2026];

const themeLogos = years.map((year) => ({
  year,
  src: `${base}/images/themes/${year}.png`,
  alt: `GirlCon ${year} theme logo`,
}));
---

<section id="past-events" class="py-24 bg-white overflow-hidden">
  <div class="max-w-5xl mx-auto px-6 mb-12 fade-up">
    <div class="text-center">
      <p class="text-xs font-semibold tracking-[0.15em] uppercase text-[#a180be] mb-3">Our History</p>
      <h2 class="font-['Open_Sauce_Sans'] text-4xl md:text-5xl font-bold text-[#1a1225] mb-5">
        Past Events
      </h2>
      <p class="text-[#7c6f8a] max-w-lg mx-auto">
        Thank you to everyone who helped make GirlCon
        {years.map((y, i) => (
          <span>{i === years.length - 1 ? 'and ' : ''}{y}{i < years.length - 1 ? ', ' : ''}</span>
        ))} possible. We couldn't have done it without you.
      </p>
    </div>
  </div>

  <!-- Theme logos strip -->
  <div class="max-w-5xl mx-auto px-6 mb-12 fade-up" style="transition-delay: 0.1s;">
    <div class="flex flex-wrap justify-center items-center gap-5">
      {themeLogos.map((logo) => (
        <img
          src={logo.src}
          alt={logo.alt}
          class="h-14 w-auto object-contain opacity-90 hover:opacity-100 transition-opacity"
          loading="lazy"
        />
      ))}
    </div>
  </div>

  <!-- Row 1: scrolls left (filled by JS) -->
  <div class="photo-marquee-wrap overflow-hidden fade-up" style="transition-delay: 0.1s;">
    <div id="marquee-row-1" class="photo-marquee-track flex items-center gap-4 w-max py-3"></div>
  </div>

  <!-- Row 2: scrolls right (filled by JS) -->
  <div class="photo-marquee-wrap overflow-hidden fade-up" style="transition-delay: 0.2s;">
    <div id="marquee-row-2" class="photo-marquee-track-reverse flex items-center gap-4 w-max py-3"></div>
  </div>
</section>

<script define:vars={{ allPhotos }}>
  function shuffle(arr) {
    const a = [...arr];
    for (let i = a.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [a[i], a[j]] = [a[j], a[i]];
    }
    return a;
  }

  function buildCard(photo, gradient) {
    const card = document.createElement('div');
    card.className = 'w-72 rounded-2xl overflow-hidden shadow-md shadow-purple-100/50 flex-shrink-0';

    const img = document.createElement('img');
    img.src = photo.src;
    img.alt = photo.alt;
    img.className = 'w-full h-52 object-cover';
    img.loading = 'lazy';

    const fallback = document.createElement('div');
    fallback.className = 'w-full h-52 hidden items-center justify-center';
    fallback.style.background = gradient;

    img.onerror = () => {
      img.style.display = 'none';
      fallback.style.display = 'flex';
    };

    card.appendChild(img);
    card.appendChild(fallback);
    return card;
  }

  const shuffled = shuffle(allPhotos);
  const mid = Math.ceil(shuffled.length / 2);
  const row1 = shuffled.slice(0, mid);
  const row2 = shuffled.slice(mid);

  const grad1 = 'linear-gradient(135deg, #f3ecf8 0%, #e0cff0 100%)';
  const grad2 = 'linear-gradient(135deg, #e0cff0 0%, #d5bef5 100%)';

  function fillRow(id, photos, gradient) {
    const el = document.getElementById(id);
    if (!el) return;
    // Duplicate for seamless loop
    [...photos, ...photos].forEach((photo) => {
      el.appendChild(buildCard(photo, gradient));
    });
  }

  fillRow('marquee-row-1', row1, grad1);
  fillRow('marquee-row-2', row2, grad2);
</script>
