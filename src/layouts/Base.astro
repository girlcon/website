---
import '../styles/global.css';
import Nav from '../components/Nav.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "GirlCon — International Tech Conference for Womxn",
  description = "GirlCon is a student-led international tech conference empowering the next generation of womxn leaders through keynotes, workshops, and networking.",
} = Astro.props;

const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href={`${base}GC.svg`} />

    <!-- Open Sauce Sans (self-hosted) -->
    <Fragment set:html={`<style>@font-face{font-family:'Open Sauce Sans';src:url('${base}fonts/open-sauce.sans-bold.ttf') format('truetype');font-weight:700;font-style:normal;font-display:swap;}</style>`} />

    <!-- Fonts: DM Sans (body) via Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>

  <body>
    <Nav />
    <main>
      <slot />
    </main>

    <!-- Global scroll-triggered fade-up observer -->
    <script>
      const fadeEls = document.querySelectorAll('.fade-up');
      if (fadeEls.length) {
        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((e) => {
              if (e.isIntersecting) {
                e.target.classList.add('visible');
                obs.unobserve(e.target);
              }
            });
          },
          { threshold: 0.12 }
        );
        fadeEls.forEach((el) => obs.observe(el));
      }
    </script>
  </body>
</html>
