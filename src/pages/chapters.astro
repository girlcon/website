---
import Base from '../layouts/Base.astro';
import Contact from '../components/Contact.astro';
import { chapters } from '../data/chapters.js';

const statusLabel = {
  active:    { text: "Active",      bg: "bg-[#e6f4ea]", color: "text-[#2d7a3f]" },
  launching: { text: "Coming Soon", bg: "bg-[#f3ecf8]", color: "text-[#6b4fa0]" },
  past:      { text: "Past",        bg: "bg-[#f0f0f0]", color: "text-[#6b6b6b]" },
};
---

<Base
  title="GirlCon Chapters — GirlCon"
  description="GirlCon is expanding globally. See where we've been and where we're going next."
>

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6 bg-[#fff8f4] text-center">
    <p class="text-xs font-semibold tracking-[0.15em] uppercase text-[#a180be] mb-4">Global Expansion</p>
    <h1 class="font-['Open_Sauce_Sans'] text-5xl md:text-7xl font-bold text-[#1a1225] mb-5">
      GirlCon Chapters
    </h1>
    <p class="text-[#7c6f8a] text-lg max-w-xl mx-auto">
      GirlCon is expanding around the world. See where we've held events and where we're headed next.
    </p>
  </section>

  <!-- Chapter cards -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-['Open_Sauce_Sans'] text-3xl md:text-4xl font-bold text-[#1a1225] mb-4">
          Our Chapters
        </h2>
        <p class="text-[#7c6f8a] max-w-lg mx-auto">
          Each chapter brings GirlCon's mission — connecting and inspiring the next generation of women in tech — to a new city.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        {chapters.map((chapter) => {
          const badge = statusLabel[chapter.status];
          return (
            <div class="flex flex-col rounded-2xl border border-purple-100 bg-[#fff8f4] overflow-hidden hover:shadow-md hover:shadow-purple-900/8 transition-shadow">
              <!-- Color band -->
              <div class="h-2" style="background: linear-gradient(90deg, #a180be, #6b4fa0);" />

              <div class="flex flex-col gap-3 p-6 flex-1">
                <!-- City + badge -->
                <div class="flex items-start justify-between gap-2">
                  <h3 class="font-['Open_Sauce_Sans'] text-xl font-bold text-[#1a1225]">
                    {chapter.city}
                  </h3>
                  <span class={`shrink-0 text-xs font-semibold px-2.5 py-1 rounded-full ${badge.bg} ${badge.color}`}>
                    {badge.text}
                  </span>
                </div>

                <!-- Year (for past chapters) -->
                {chapter.year && (
                  <p class="text-xs font-semibold tracking-wide text-[#a180be] uppercase">{chapter.year}</p>
                )}

                <!-- Description -->
                <p class="text-sm text-[#7c6f8a] flex-1">{chapter.description}</p>

                <!-- Instagram -->
                {chapter.instagram && (
                  <div class="pt-2">
                    <a
                      href={`https://instagram.com/${chapter.instagram}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="text-xs font-medium text-[#6b4fa0] hover:text-[#3d2466] transition-colors"
                    >
                      @{chapter.instagram}
                    </a>
                  </div>
                )}
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- What chapters look like -->
  <section class="py-20 px-6 bg-[#fff8f4]">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-['Open_Sauce_Sans'] text-3xl md:text-4xl font-bold text-[#1a1225] mb-4">
          What Happens at a Chapter?
        </h2>
        <p class="text-[#7c6f8a] max-w-lg mx-auto">
          GirlCon produces and runs each chapter, bringing our full conference experience to communities around the world.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {[
          { icon: "🎤", title: "Keynote Speakers", desc: "Hear from inspiring women across tech, business, and creative industries" },
          { icon: "🛠", title: "Tech+ Sessions", desc: "Hands-on breakout sessions highlighting technology + other fields" },
          { icon: "🤝", title: "Networking", desc: "Connect with peers, mentors, and potential employers from leading companies" },
        ].map((item) => (
          <div class="text-center p-6 rounded-2xl bg-white border border-purple-50">
            <p class="text-4xl mb-4">{item.icon}</p>
            <h3 class="font-['Open_Sauce_Sans'] font-bold text-lg text-[#1a1225] mb-2">{item.title}</h3>
            <p class="text-sm text-[#7c6f8a]">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <Contact />
</Base>
