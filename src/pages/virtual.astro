---
import Base from '../layouts/Base.astro';
import Contact from '../components/Contact.astro';
import { virtualKeynotes, virtualTechSessions, virtualProfDevSessions } from '../data/virtual-speakers.js';

function initials(name) {
  return name.split(' ').map((n) => n[0]).join('').slice(0, 2).toUpperCase();
}

const allModalSpeakers = [
  ...virtualKeynotes.map((s, i) => ({
    id: `k${i}`,
    name: s.name,
    title: s.title,
    bio: s.bio,
    photo: s.photo,
    links: s.links || [],
  })),
  ...virtualTechSessions.map((s, i) => s.bio ? {
    id: `t${i}`,
    name: s.speakerName,
    title: s.speakerTitle,
    bio: s.bio,
    photo: s.photo,
    links: s.links || [],
  } : null).filter(Boolean),
  ...virtualProfDevSessions.map((s, i) => s.bio ? {
    id: `p${i}`,
    name: s.speakerName,
    title: s.speakerTitle,
    bio: s.bio,
    photo: s.photo,
    links: s.links || [],
  } : null).filter(Boolean),
];
---

<Base
  title="GirlCon Virtual — GirlCon"
  description="GirlCon Virtual is our online conference welcoming attendees from around the world. Featuring live-streamed keynotes and interactive virtual workshops."
>

  <!-- Hero -->
  <section class="pt-32 pb-20 px-6 bg-[#fff8f4] text-center">
    <p class="text-xs font-semibold tracking-[0.15em] uppercase text-[#a180be] mb-4">Online · Worldwide</p>
    <h1 class="font-['Open_Sauce_Sans'] text-5xl md:text-7xl font-bold text-[#1a1225] mb-5">
      GirlCon Virtual
    </h1>
    <p class="text-[#7c6f8a] text-lg max-w-xl mx-auto mb-10">
      Our online conference welcoming future leaders from across the globe — live-streamed keynotes, virtual workshops, and worldwide connections.
    </p>
    <div class="flex flex-wrap justify-center gap-3">
      <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[#f3ecf8] text-[#6b4fa0] font-medium text-sm">
        🗓 June 25–26, 2026
      </div>
      <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-[#f3ecf8] text-[#6b4fa0] font-medium text-sm">
        💻 Online
      </div>
    </div>
  </section>

  <!-- Registration CTA -->
  <section class="py-16 px-6" style="background: linear-gradient(135deg, #a180be, #6b4fa0);">
    <div class="max-w-xl mx-auto text-center">
      <h2 class="font-['Open_Sauce_Sans'] text-3xl font-bold text-white mb-4">Register for GirlCon Virtual 2026</h2>
      <p class="text-purple-200 mb-8">Secure your free spot for June 25–26, 2026 — online and open to all!</p>
      <a
        href="https://www.eventbrite.com/e/girlcon-2026-virtual-tickets-1990421786143"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full bg-white text-[#6b4fa0] font-semibold hover:opacity-90 transition-opacity"
      >
        Register Now →
      </a>
    </div>
  </section>

  <!-- Why Virtual -->
  <section class="py-20 px-6 bg-white">
    <div class="max-w-4xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-['Open_Sauce_Sans'] text-3xl md:text-4xl font-bold text-[#1a1225] mb-4">
          Why GirlCon Virtual?
        </h2>
        <p class="text-[#7c6f8a] max-w-lg mx-auto">
          Our virtual conference removes barriers — no matter where you are in the world, you're welcome at GirlCon.
        </p>
      </div>

      <div class="grid md:grid-cols-3 gap-8">
        {[
          { icon: "🌎", title: "35+ Countries", desc: "Attendees from around the world join us online, bringing global perspectives" },
          { icon: "💻", title: "Live & Interactive", desc: "Participate live via Q&A, polls, and virtual networking rooms with other attendees" },
          { icon: "🆓", title: "Always Free", desc: "GirlCon Virtual is completely free to attend — open to anyone, anywhere" },
        ].map((item) => (
          <div class="text-center p-6 rounded-2xl bg-[#fff8f4] border border-purple-50">
            <p class="text-4xl mb-4">{item.icon}</p>
            <h3 class="font-['Open_Sauce_Sans'] font-bold text-lg text-[#1a1225] mb-2">{item.title}</h3>
            <p class="text-sm text-[#7c6f8a]">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Speakers -->
  <section class="py-20 px-6 bg-[#fff8f4]">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-14">
        <h2 class="font-['Open_Sauce_Sans'] text-3xl md:text-4xl font-bold text-[#1a1225]">Speakers</h2>
      </div>

      <!-- Keynotes -->
      <div class="mb-16">
        <div class="text-center mb-10">
          <span class="inline-block bg-[#ede4f7] text-[#6b4fa0] text-xs font-bold tracking-[0.12em] uppercase px-5 py-2 rounded-full">
            🎤 Keynotes
          </span>
        </div>
        <div class="flex flex-wrap justify-center gap-6">
          {virtualKeynotes.map((speaker, i) => (
            <button
              class="speaker-card flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm border border-purple-50 w-[calc(50%-12px)] md:w-52 text-left cursor-pointer hover:shadow-md hover:border-purple-200 transition-all"
              data-speaker-id={`k${i}`}
            >
              <div class="overflow-hidden aspect-square shrink-0">
                {speaker.photo
                  ? <img src={speaker.photo} alt={speaker.name} class="w-full h-full object-cover object-top" />
                  : <div class="w-full h-full flex items-center justify-center text-3xl font-bold text-[#6b4fa0]" style="background: linear-gradient(135deg, #f3ecf8 0%, #e0cff0 100%);">{initials(speaker.name)}</div>
                }
              </div>
              <div class="flex flex-col flex-1 px-4 pt-4 pb-5 text-center">
                <p class="font-semibold text-[#1a1225] text-sm">{speaker.name}</p>
                <p class="text-xs text-[#a180be] font-medium mt-1 leading-snug">{speaker.title}</p>
              </div>
            </button>
          ))}
        </div>
      </div>

      <!-- Tech+ Sessions -->
      <div class="mb-16">
        <div class="text-center mb-10">
          <span class="inline-block bg-[#ede4f7] text-[#6b4fa0] text-xs font-bold tracking-[0.12em] uppercase px-5 py-2 rounded-full">
            💻 Tech+ Sessions
          </span>
        </div>
        <div class="flex flex-wrap justify-center gap-6">
          {virtualTechSessions.map((speaker, i) => (
            speaker.bio ? (
              <button
                class="speaker-card flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm border border-purple-50 w-[calc(50%-12px)] md:w-52 text-left cursor-pointer hover:shadow-md hover:border-purple-200 transition-all"
                data-speaker-id={`t${i}`}
              >
                <div class="aspect-square overflow-hidden shrink-0">
                  {speaker.photo
                    ? <img src={speaker.photo} alt={speaker.speakerName} class="w-full h-full object-cover object-center" />
                    : <div class="w-full h-full flex items-center justify-center text-2xl font-bold text-[#6b4fa0]" style="background: linear-gradient(135deg, #f3ecf8 0%, #e0cff0 100%);">{initials(speaker.speakerName)}</div>
                  }
                </div>
                <div class="flex flex-col flex-1 px-4 pt-3 pb-4 text-center">
                  <p class="font-bold text-sm text-[#1a1225] leading-snug">{speaker.speakerName}</p>
                  <p class="text-xs text-[#a180be] font-medium mt-1 leading-snug">{speaker.sessionTitle}</p>
                </div>
              </button>
            ) : (
              <div class="flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm border border-purple-50 w-[calc(50%-12px)] md:w-52">
                <div class="aspect-square shrink-0 flex items-center justify-center" style="background: linear-gradient(135deg, #f3ecf8 0%, #e0cff0 100%);">
                  <span class="text-2xl font-bold text-[#6b4fa0]">{initials(speaker.speakerName)}</span>
                </div>
                <div class="flex flex-col flex-1 px-4 pt-3 pb-4 text-center">
                  <p class="font-bold text-sm text-[#1a1225] leading-snug">{speaker.speakerName}</p>
                  <p class="text-xs text-[#a180be] font-medium mt-1 leading-snug">{speaker.sessionTitle}</p>
                </div>
              </div>
            )
          ))}
        </div>
      </div>

      <!-- Professional Development -->
      <div>
        <div class="text-center mb-10">
          <span class="inline-block bg-[#ede4f7] text-[#6b4fa0] text-xs font-bold tracking-[0.12em] uppercase px-5 py-2 rounded-full">
            💼 Professional Development
          </span>
        </div>
        <div class="flex flex-wrap justify-center gap-6">
          {virtualProfDevSessions.map((speaker, i) => (
            speaker.bio ? (
              <button
                class="speaker-card flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm border border-purple-50 w-[calc(50%-12px)] md:w-52 text-left cursor-pointer hover:shadow-md hover:border-purple-200 transition-all"
                data-speaker-id={`p${i}`}
              >
                <div class="aspect-square overflow-hidden shrink-0">
                  {speaker.photo
                    ? <img src={speaker.photo} alt={speaker.speakerName} class="w-full h-full object-cover object-center" />
                    : <div class="w-full h-full flex items-center justify-center text-2xl font-bold text-[#6b4fa0]" style="background: linear-gradient(135deg, #f3ecf8 0%, #e0cff0 100%);">{initials(speaker.speakerName)}</div>
                  }
                </div>
                <div class="flex flex-col flex-1 px-4 pt-3 pb-4 text-center">
                  <p class="font-bold text-sm text-[#1a1225] leading-snug">{speaker.speakerName}</p>
                  <p class="text-xs text-[#a180be] font-medium mt-1 leading-snug">{speaker.sessionTitle}</p>
                </div>
              </button>
            ) : (
              <div class="flex flex-col bg-white rounded-2xl overflow-hidden shadow-sm border border-purple-50 w-[calc(50%-12px)] md:w-52">
                <div class="aspect-square shrink-0 flex items-center justify-center" style="background: linear-gradient(135deg, #f3ecf8 0%, #e0cff0 100%);">
                  <span class="text-2xl font-bold text-[#6b4fa0]">{initials(speaker.speakerName)}</span>
                </div>
                <div class="flex flex-col flex-1 px-4 pt-3 pb-4 text-center">
                  <p class="font-bold text-sm text-[#1a1225] leading-snug">{speaker.speakerName}</p>
                  <p class="text-xs text-[#a180be] font-medium mt-1 leading-snug">{speaker.sessionTitle}</p>
                </div>
              </div>
            )
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Speaker Bio Modal -->
  <div id="speaker-modal" class="fixed inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-200" style="background: rgba(26,18,37,0.6); backdrop-filter: blur(4px);">
    <div id="modal-panel" class="bg-white rounded-3xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl relative scale-95 transition-transform duration-200">
      <button id="modal-close" class="absolute top-4 right-4 w-9 h-9 flex items-center justify-center rounded-full bg-[#f3ecf8] text-[#6b4fa0] hover:bg-[#ede4f7] transition-colors text-xl font-bold z-10" aria-label="Close">×</button>
      <div class="flex flex-col sm:flex-row gap-6 p-8 pb-4">
        <div id="modal-photo" class="shrink-0 w-full sm:w-36 h-48 sm:h-36 rounded-2xl overflow-hidden"></div>
        <div class="flex flex-col justify-center">
          <p id="modal-name" class="font-['Open_Sauce_Sans'] text-2xl font-bold text-[#1a1225]"></p>
          <p id="modal-title" class="text-[#a180be] font-medium mt-1 text-sm"></p>
          <div id="modal-links" class="flex gap-1 mt-2"></div>
        </div>
      </div>
      <p id="modal-bio" class="px-8 pb-8 pt-2 text-[#7c6f8a] leading-relaxed text-sm"></p>
    </div>
  </div>

  <script define:vars={{ speakers: allModalSpeakers }}>
    const speakerMap = {};
    speakers.forEach((s) => { speakerMap[s.id] = s; });

    const modal = document.getElementById('speaker-modal');
    const modalPanel = document.getElementById('modal-panel');
    const modalClose = document.getElementById('modal-close');
    const modalName = document.getElementById('modal-name');
    const modalTitle = document.getElementById('modal-title');
    const modalLinks = document.getElementById('modal-links');
    const modalBio = document.getElementById('modal-bio');
    const modalPhoto = document.getElementById('modal-photo');

    const ICONS = {
      linkedin: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0H5C2.239 0 0 2.239 0 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5V5c0-2.761-2.238-5-5-5zM8 19H5V8h3v11zM6.5 6.732c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zM20 19h-3v-5.604c0-3.368-4-3.113-4 0V19h-3V8h3v1.765c1.396-2.586 7-2.777 7 2.476V19z"/></svg>',
      instagram: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>',
      website: '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>',
    };

    function initials(name) {
      return name.split(' ').map((n) => n[0]).join('').slice(0, 2).toUpperCase();
    }

    function openModal(speaker) {
      modalName.textContent = speaker.name;
      modalTitle.textContent = speaker.title;
      if (speaker.links && speaker.links.length > 0) {
        modalLinks.innerHTML = speaker.links.map(l =>
          `<a href="${l.url}" target="_blank" rel="noopener noreferrer" title="${l.type}" style="color:#a180be;display:inline-flex;align-items:center;padding:4px;border-radius:6px;transition:color 0.15s;" onmouseover="this.style.color='#6b4fa0'" onmouseout="this.style.color='#a180be'">${ICONS[l.type]}</a>`
        ).join('');
        modalLinks.style.display = 'flex';
      } else {
        modalLinks.innerHTML = '';
        modalLinks.style.display = 'none';
      }
      modalBio.innerHTML = speaker.bio.split('\n\n').map(p => `<p class="mb-3 last:mb-0">${p}</p>`).join('');
      modalPhoto.innerHTML = speaker.photo
        ? `<img src="${speaker.photo}" alt="${speaker.name}" class="w-full h-full object-cover object-top" />`
        : `<div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:2rem;font-weight:700;color:#6b4fa0;background:linear-gradient(135deg,#f3ecf8 0%,#e0cff0 100%);">${initials(speaker.name)}</div>`;
      modal.classList.remove('opacity-0', 'pointer-events-none');
      modal.classList.add('opacity-100');
      modalPanel.classList.remove('scale-95');
      modalPanel.classList.add('scale-100');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal.classList.add('opacity-0', 'pointer-events-none');
      modal.classList.remove('opacity-100');
      modalPanel.classList.add('scale-95');
      modalPanel.classList.remove('scale-100');
      document.body.style.overflow = '';
    }

    document.querySelectorAll('[data-speaker-id]').forEach((card) => {
      card.addEventListener('click', () => {
        const speaker = speakerMap[card.dataset.speakerId];
        if (speaker) openModal(speaker);
      });
    });

    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  </script>

  <Contact />
</Base>
